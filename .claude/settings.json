{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null); [ -n \"$ROOT\" ] && [ -x \"$ROOT/.claude/hooks/verify-all.sh\" ] && \"$ROOT/.claude/hooks/verify-all.sh\"'",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/plan-mode-gate.sh"
          }
        ]
      }
    ]
  }
}
